# ==============================================================
# ReviewHive — environment variables
# Copy to `.env` and fill in. NEVER commit `.env` to version control.
# ==============================================================

# ---------- Frontend (baked into the build via Vite) ----------
# These are PUBLIC values — safe to ship in the client bundle.
VITE_SUPABASE_URL=REPLACE_ME_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=REPLACE_ME_SUPABASE_ANON_KEY

# ---------- Edge Functions (secrets — set via `supabase secrets set`) ----------
# These are NEVER exposed to the browser. Manage via:
#   supabase secrets set KEY=value --env-file .env
# or in the Supabase dashboard: Project Settings > Edge Functions > Secrets.

# Used by edge functions to bypass RLS for admin actions.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_SUPABASE_SERVICE_ROLE_KEY

# Transactional email (magic links, application updates, payout notifications).
RESEND_API_KEY=REPLACE_ME_RESEND_API_KEY

# Razorpay Payouts — used by trigger-payout edge function.
# NOTE: Razorpay integration is currently STUBBED in supabase/functions/trigger-payout/index.ts.
# Uncomment the live block once keys are production-ready.
RAZORPAY_KEY_ID=REPLACE_ME_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_ME_RAZORPAY_KEY_SECRET
RAZORPAY_ACCOUNT_NUMBER=REPLACE_ME_RAZORPAY_ACCOUNT_NUMBER

# MSG91 — used as Supabase Auth custom SMS/WhatsApp provider.
# Configure via: Supabase Dashboard > Authentication > Phone Auth > Custom SMS.
MSG91_AUTH_KEY=REPLACE_ME_MSG91_AUTH_KEY
MSG91_WHATSAPP_TEMPLATE_ID=REPLACE_ME_MSG91_WHATSAPP_TEMPLATE_ID

# Application URL — used in emails and redirect links.
APP_URL=https://reviewhive.in

# TDS percentage for payout deductions (e.g. 10 for 10%).
TDS_PERCENT=10
